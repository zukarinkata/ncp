<?php
require_once 'config.php';

$error = '';
$success = '';

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $username = trim($_POST['username'] ?? '');
    
    if (empty($username)) {
        $error = 'نام کاربری اجباری است.';
    } else {
        // چک وجود کاربر و نقش (مثال: فقط admin می‌تواند ریست کند)
        $stmt = $conn->prepare("SELECT id, role FROM users WHERE username = ?");
        $stmt->bind_param("s", $username);
        $stmt->execute();
        $result = $stmt->get_result();
        
        if ($row = $result->fetch_assoc()) {
            // ریست به رمز پیش‌فرض (تغییر دهید)
            $default_password = 'ncp';
            $new_hash = password_hash($default_password, PASSWORD_DEFAULT);
            
            $update_stmt = $conn->prepare("UPDATE users SET password_hash = ? WHERE id = ?");
            $update_stmt->bind_param("si", $new_hash, $row['id']);
            
            if ($update_stmt->execute()) {
                $success = "رمز عبور ریست شد برای ورود رمز عبور را از مدیر سوال کنید و وارد شوید.";
            } else {
                $error = 'خطا در ریست رمز: ' . $update_stmt->error;
            }
            $update_stmt->close();
        } else {
            $error = 'نام کاربری یافت نشد.';
        }
        $stmt->close();
    }
}
?>

